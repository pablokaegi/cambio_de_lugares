# Copiar como .env y completar con valores reales
# NUNCA commitear el archivo .env — agregar a .gitignore

# Clave secreta para sesiones Flask (usar una cadena aleatoria larga)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplazar-con-una-cadena-aleatoria-de-64-caracteres

# Base de datos en producción (MySQL / cPanel)
# DATABASE_URL=mysql+pymysql://usuario:contraseña@host:3306/nombre_bd
